rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /workspaces/{workspaceId} {
      allow read, write: if signedIn();
    }

    match /users/{studentId} {
      allow read, write: if signedIn();
    }
  }
}
